{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": "http://localhost:4200"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "<tenant-id>",
    "ClientId": "<api-app-client-id>",
    "Audience": "api://<api-app-client-id>"
  },
  "AccessControl": {
    "AdminGroupObjectId": "<admin-ad-group-object-id>",
    "BypassAuthInDevelopment": false
  },
  "BlobDataset": {
    "AccountUrl": "https://<storage-account>.blob.core.windows.net",
    "Container": "readacross",
    "DatasetPrefix": "datasets/current",
    "MediaSasMinutes": 15
  },
  "ConnectionStrings": {
    "//": "AAD/Managed-Identity connection. No User ID / Password — token is injected at runtime by DefaultAzureCredential.",
    "AzureSqlDb": "Server=tcp:<your-sql-server>.database.windows.net,1433;Database=<your-database>;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "DashboardConfig": {
    "//":            "Surfaced verbatim by GET /api/Insights/dashboard-config. Mirrors the legacy offline dashboard's top-level chrome (feedback recipient, Wave deep-link base URLs, per-workstream data-quality blocks).",
    "FeedbackEmail": "greg_shannon@mckinsey.com",
    "WaveBaseUrls": {
      "cosma":      "https://magna-cosma.mckinseywave.com",
      "powertrain": "https://magna-powertrain.mckinseywave.com",
      "ignite":     "https://magna-ignite.mckinseywave.com"
    },
    "CosmaMeta": {
      "TotalRaw":           0,
      "TotalActive":        0,
      "TotalCategorized":   0,
      "TotalUncategorized": 0,
      "ValidationNotes":    [],
      "ExclusionRules":     []
    },
    "PowertrainMeta": {
      "TotalRaw":         0,
      "TotalActive":      0,
      "TotalCategorized": 0,
      "TotalNeedsReview": 0,
      "ValidationNotes":  [],
      "ExclusionRules":   []
    },
    "ExteriorsMeta": {
      "TotalRaw":         0,
      "TotalActive":      0,
      "TotalCategorized": 0,
      "TotalNeedsReview": 0,
      "ValidationNotes":  [],
      "ExclusionRules":   []
    }
  }
}
